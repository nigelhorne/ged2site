<!DOCTYPE HTML PUBLIC "-//W3C//DTD HTML 4.01 Transitional//FR"
    "http://www.w3.org/TR/html4/loose.dtd">
<html lang="fr" dir="ltr">
	<head>
		<title>H&eacute;ritage dans [% SiteTitle.Default.join(' ') %]</title>
		<meta http-equiv="Content-Language" content="French">
		<link rel="stylesheet" href="/css/web.css" type="text/css" media="screen">
	</head>
	<body>
		<div id="header_container">
			<center>
				<h1>H&eacute;ritage dans [% SiteTitle.Default.join(' ') %]</h1>
				[% IF error %]
					<p><font color="red" size="+2">[% error %]</font></p>
				[% END %]
			</center>
		</div>
		<div id="container">
			<center>
				[ <a href="?page=home">Accueil</a> ] |
				[ <a href="?page=censuses">Index des Recensements</a> ] |
				[ <a href="?page=surnames">Index des Noms</a> ] |
				[ <a href="?page=history">Histoire Familiale</a> ] |
				[ <a href="?page=emigrants">Emigr&eacute;s</a> ] |
				[ <a href="?page=calendar">Calendrier</a> ] |
				[ <a href="?page=graphs">Analytique</a> ]
			</center>
			<br>
			[% IF heritage_by_country %]
				[% FOREACH country IN heritage_by_country.keys.sort %]
					<h2>[% country %]</h2>
					<table>
						<tr>
							<th>Nom</th>
							<th>Lien de parent&eacute;</th>
							<th>N&eacute;(e) le</th>
						</tr>
						[% FOREACH person IN heritage_by_country.$country %]
							<tr>
								<td><a href="?page=people&amp;entry=[%- person.entry %]">[% person.title %]</a></td>
								<td>[% person.relationship %]</td>
								<td>[% person.dob %]</td>
							</tr>
						[% END %]
					</table>
				[% END %]
			[% ELSE %]
				<p>Aucun h&eacute;ritage trouv&eacute; en dehors du pays d&rsquo;origine.</p>
			[% END %]
		</div>
		<p align="right">
			<i>
			Cette site web a &eacute;t&eacute; cr&eacute;&eacute; par <a href="https://github.com/nigelhorne/ged2site">Ged2Site</a>.
			[% IF updated %]
				[% USE date %]
				Derni&egrave;re modification le [% date.format(time = updated, format = '%d %b %Y', locale = lingua.language_code_alpha2) %]
			[% END %]
			</i>
		</p>
	</body>
</html>
