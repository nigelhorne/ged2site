<!DOCTYPE HTML PUBLIC "-//W3C//DTD HTML 4.01 Transitional//EN"
    "http://www.w3.org/TR/html4/loose.dtd">
<html lang="en">
	<head>
		<title>Heritage for [% SiteTitle.Default.join(' ') %]</title>
		<meta http-equiv="Content-Language" content="English">
		<link rel="stylesheet" href="/css/web.css" type="text/css" media="screen">
		<meta name="description" content="Heritage in [% SiteTitle.Default.join(' ') %] - A Ged2Site webpage">
		<meta name="Copyright" content="Copyright (C) 2026 Nigel Horne">
	</head>
	<body>
		<div id="header_container">
			<center>
				<h1>Heritage for [% SiteTitle.Default.join(' ') %]</h1>
				[% IF error %]
					<p><font color="red" size="+2">[% error %]</font></p>
				[% END %]
			</center>
		</div>
		<div id="container">
			<center>
				[ <a href="?page=people&amp;home=1">Home</a> ] |
				[ <a href="?page=censuses">Census Index</a> ] |
				[ <a href="?page=surnames">Surname Index</a> ] |
				[ <a href="?page=history">Family History</a> ] |
				[ <a href="?page=emigrants">Emigrants</a> ] |
				[ <a href="?page=calendar">Calendar</a> ] |
				[ <a href="?page=graphs">Analytics</a> ]
			</center>
			<br>
			[% IF heritage_by_country %]
				[% FOREACH country IN heritage_by_country.keys.sort %]
					<h2>[% country %]</h2>
					<table>
						<tr>
							<th>Name</th>
							<th>Relationship</th>
							<th>Born</th>
						</tr>
						[% FOREACH person IN heritage_by_country.$country %]
							<tr>
								<td><a href="?page=people&amp;entry=[%- person.entry %]">[% person.title %]</a></td>
								<td>[% person.relationship %]</td>
								<td>[% person.dob %]</td>
							</tr>
						[% END %]
					</table>
				[% END %]
			[% ELSE %]
				<p>No heritage found outside the home country.</p>
			[% END %]
		</div>
		<p align="right">
			<i>
			This website was generated by <a href="//github.com/nigelhorne/ged2site">Ged2Site</a>.
			[% IF updated %]
				[% USE date %]
				Last updated on [% date.format(time = updated, format = '%d %b %Y', locale = lingua.language_code_alpha2) %]
			[% END %]
			</i>
		</p>
	</body>
</html>
